// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. ตารางผู้ใช้งานระบบ (สำหรับ Login)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          String    @default("USER") // เช่น ADMIN, TEACHER, STUDENT
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 2. ตารางข้อมูลนักเรียน (สำหรับจัดการประวัตินักเรียน)
model Student {
  id          String   @id @default(cuid())
  studentId   String   @unique // เลขประจำตัวนักเรียน เช่น 66001
  firstName   String
  lastName    String
  grade       String   // ชั้นเรียน เช่น ม.1/1
  gender      String?  // เพศ (ใส่ ? เพื่อให้เป็นค่าว่างได้)
  birthDate   DateTime?
  address     String?
  parentPhone String?  // เบอร์ติดต่อผู้ปกครอง
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
